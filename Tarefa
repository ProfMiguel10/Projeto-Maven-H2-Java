package br.crud.model;


public class Tarefa {
	private int id;
	private String descricao;
	private boolean concluida;

	// Construtores
	public Tarefa() {
	}

	public Tarefa(int id, String descricao, boolean concluida) {
		this.id = id;
		this.descricao = descricao;
		this.concluida = concluida;
	}

	// Getters e Setters
	public int getId() {
		return id;
	}

	public void setId(int id) {
		this.id = id;
	}

	public String getDescricao() {
		return descricao;
	}

	public void setDescricao(String descricao) {
		this.descricao = descricao;
	}

	public boolean isConcluida() {
		return concluida;
	}

	public void setConcluida(boolean concluida) {
		this.concluida = concluida;
	}

	// Sobrescrever o toString ajuda a mostrar o resultado no console de forma
	// bonita
	@Override
	public String toString() {
		return String.format("[%d] %s - %s", id, descricao, concluida ? "✓ Concluída" : "⭘ Pendente");
	}
}
